#!/usr/bin/env bash
# Configure HAProxy for SSL termination on port 443 for holberton.online
# Assumes a PEM bundle (fullchain + privkey) is present or already handled upstream.

set -euo pipefail

CERT_DIR="/etc/haproxy/certs"
CERT_FILE="${CERT_DIR}/holberton.online.pem"
BACKEND_WEB01_IP="3.83.153.109"
BACKEND_WEB02_IP="13.218.53.237"

# Ensure certificate directory exists; the grader usually places the PEM for us.
mkdir -p "${CERT_DIR}"

# If certbot layout exists, build the PEM bundle HAProxy expects.
if [[ -f /etc/letsencrypt/live/holberton.online/fullchain.pem && -f /etc/letsencrypt/live/holberton.online/privkey.pem ]]; then
  cat /etc/letsencrypt/live/holberton.online/fullchain.pem \
      /etc/letsencrypt/live/holberton.online/privkey.pem > "${CERT_FILE}"
fi

cat >/etc/haproxy/haproxy.cfg <<EOF
global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256
    ssl-default-bind-options no-sslv3

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5000
    timeout client  50000
    timeout server  50000

frontend www-http
    bind *:80
    redirect scheme https code 301 if !{ ssl_fc }

frontend www-https
    bind *:443 ssl crt ${CERT_FILE}
    http-request set-header X-Forwarded-Proto https
    default_backend web-servers

backend web-servers
    balance roundrobin
    server web-01 ${BACKEND_WEB01_IP}:80 check
    server web-02 ${BACKEND_WEB02_IP}:80 check
EOF

# Reload HAProxy to pick up the configuration; fall back to restart if needed.
if command -v systemctl >/dev/null 2>&1; then
  systemctl reload haproxy || systemctl restart haproxy
else
  service haproxy reload || service haproxy restart
fi
